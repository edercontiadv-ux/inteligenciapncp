# Banco de dados (PostgreSQL / Supabase)
DATABASE_URL="postgresql://usuario:senha@host:5432/postgres"

# JWT
JWT_SECRET=sua_chave_secreta_aqui
JWT_EXPIRES_IN=15m

# Provedor LLM para depuração de termos: anthropic | openai | fallback
LLM_PROVIDER=fallback

# Chave da API Anthropic (necessário se LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-api03-SUA-CHAVE-AQUI

# Chave da API OpenAI (necessário se LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-SUA-CHAVE-AQUI
# OPENAI_API_BASE_URL=https://api.openai.com/v1

# URL base da API do PNCP (não altere)
PNCP_API_BASE_URL=https://pncp.gov.br/api/consulta/v1

# URL pública do site (para Open Graph / metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000


