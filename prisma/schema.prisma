generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String    @id @default(uuid())
  name             String
  email            String    @unique
  passwordHash     String    @map("password_hash")
  role             String    @default("user")
  tokenVersion     Int       @default(0) @map("token_version")
  createdAt        DateTime  @default(now()) @map("created_at")

  clients          Client[]
  tasks            Task[]
  subscriptions    Subscription[]
  searchLogs       SearchLog[]

  @@map("users")
}

model RefreshTokenBlacklist {
  id        String   @id @default(uuid())
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("refresh_token_blacklist")
}

model Client {
  id        String   @id @default(uuid())
  name      String   @map("name")
  document  String   @map("document")
  email     String?
  phone     String?
  notes     String?
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tasks Task[]
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("clients")
  @@index([userId], name: "idx_clients_user_id")
  @@index([userId, name], name: "idx_clients_user_name")
}

model Task {
  id          String    @id @default(uuid())
  description String    @map("description")
  processNumber String  @map("process_number")
  type        String    @default("Prazo") @map("type")
  priority    String    @default("media") @map("priority")
  deadline    DateTime? @map("deadline")
  responsible String?   @map("responsible")
  status      String    @default("pendente") @map("status")
  clientId    String?   @map("client_id")
  userId      String    @map("user_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tasks")
  @@index([userId], name: "idx_tasks_user_id")
  @@index([clientId], name: "idx_tasks_client_id")
  @@index([userId, deadline], name: "idx_tasks_user_deadline")
}

model Plan {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  priceCents  Int      @map("price_cents")
  maxUsers    Int      @default(1) @map("max_users")
  maxClients  Int      @default(-1) @map("max_clients")
  maxSearches Int      @default(20) @map("max_searches")
  features    String[]
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                    String    @id @default(uuid())
  userId                String    @map("user_id")
  planId                String    @map("plan_id")
  status                String    @default("trial")
  trialEndsAt           DateTime? @map("trial_ends_at")
  currentPeriodEndsAt   DateTime? @map("current_period_ends_at")
  stripeSubscriptionId  String?   @unique @map("stripe_subscription_id")
  stripeCustomerId      String?   @map("stripe_customer_id")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])

  @@map("subscriptions")
  @@index([userId])
  @@index([planId])
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")
  action      String
  email       String
  ipAddress   String   @map("ip_address")
  userAgent   String?  @map("user_agent")
  success     Boolean
  errorReason String?  @map("error_reason")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([email])
  @@index([ipAddress])
  @@index([action])
  @@index([createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

model LoginAttempt {
  id        String   @id @default(uuid())
  email     String
  ipAddress String   @map("ip_address")
  timestamp DateTime @default(now())
  success   Boolean

  @@index([email, timestamp])
  @@index([ipAddress, timestamp])
  @@index([timestamp])
  @@map("login_attempts")
}

model RateLimit {
  id        String   @id @default(uuid())
  key       String   @unique
  count     Int      @default(1)
  resetAt   DateTime @map("reset_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("rate_limits")
}

model SearchLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  query     String
  results   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("search_logs")
  @@index([userId, createdAt])
}
